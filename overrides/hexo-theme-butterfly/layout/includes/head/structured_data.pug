if theme.structured_data && theme.structured_data.enable
  if page.layout === 'post'
    -
      const title = page.title
      const url = page.permalink
      const imageVal = page.cover_type === 'img' ? page.cover : theme.avatar.img
      const image = imageVal ? full_url_for(imageVal) : ''
      const datePublished = page.date.toISOString()
      const dateModified = (page.updated || page.date).toISOString()
      const author = page.copyright_author || config.author
      const authorHrefVal = page.copyright_author_href || theme.post_copyright.author_href || config.url
      const authorHref = full_url_for(authorHrefVal)
      const categoryItems = page.categories ? page.categories.toArray() : []
      const categoryNames = categoryItems.map(category => category.name).filter(Boolean)
      const keywordItems = [...new Set((page.keywords ? String(page.keywords).split(',') : [])
        .map(keyword => keyword.trim())
        .filter(Boolean))]
      const breadcrumbItems = [{
        "@type": "ListItem",
        "position": 1,
        "name": config.title,
        "item": full_url_for('/')
      }]

      categoryItems.forEach((category, index) => {
        breadcrumbItems.push({
          "@type": "ListItem",
          "position": index + 2,
          "name": category.name,
          "item": full_url_for(category.path)
        })
      })

      breadcrumbItems.push({
        "@type": "ListItem",
        "position": breadcrumbItems.length + 1,
        "name": title,
        "item": url
      })

      const jsonLd = {
        "@context": "https://schema.org",
        "@graph": [{
          "@type": "BlogPosting",
          "headline": title,
          "url": url,
          "image": image,
          "datePublished": datePublished,
          "dateModified": dateModified,
          "author": [{
            "@type": "Person",
            "name": author,
            "url": authorHref
          }]
        }, {
          "@type": "BreadcrumbList",
          "itemListElement": breadcrumbItems
        }]
      }

      if (keywordItems.length) jsonLd["@graph"][0].keywords = keywordItems
      if (categoryNames.length) jsonLd["@graph"][0].articleSection = categoryNames.join('/')

      jsonLdScript = JSON.stringify(jsonLd, null, 2)
    -

  else if is_home() && (!page.current || page.current === 1)
    -
      const domain = new URL(config.url).hostname
      const alternateNames = [...(theme.structured_data.alternate_name || [])]
      const socialLinks = []

      if (config.subtitle) alternateNames.push(config.subtitle)
      if (domain) alternateNames.push(domain)

      if (theme.social) {
        Object.entries(theme.social).forEach(([, value]) => {
          const parts = String(value).split('||').map(item => item.trim())
          if (parts[0] && /^https?:\/\//.test(parts[0])) socialLinks.push(parts[0])
        })
      }

      const personId = full_url_for('/#person')
      const jsonLd = {
        "@context": "https://schema.org",
        "@graph": [{
          "@type": "WebSite",
          "@id": full_url_for('/#website'),
          "name": config.title,
          "alternateName": [...new Set(alternateNames)],
          "url": full_url_for('/'),
          "potentialAction": {
            "@type": "SearchAction",
            "target": {
              "@type": "EntryPoint",
              "urlTemplate": `https://www.google.com/search?q=site:${domain}+{search_term_string}`
            },
            "query-input": "required name=search_term_string"
          }
        }, {
          "@type": "Person",
          "@id": personId,
          "name": config.author,
          "url": full_url_for('/'),
          "image": full_url_for(theme.avatar.img),
          "description": config.description,
          "sameAs": [...new Set(socialLinks)]
        }]
      }

      jsonLdScript = JSON.stringify(jsonLd, null, 2)
    -

  if jsonLdScript
    script(type="application/ld+json").
      !{jsonLdScript}
