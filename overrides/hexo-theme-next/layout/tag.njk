{% extends '_layout.njk' %}
{% import '_macro/sidebar.njk' as sidebar_template with context %}

{% block title %}{{ __('title.tag') }}: {{ page.tag }} | {{ title }}{% endblock %}

{% block class %}tag posts-expand{% endblock %}

{% block content %}

  <div class="post-block">
    <div class="post-content">
      <div class="collection-title">
        <h1 class="collection-header">
          {{- page.tag }}
          <small>{{ __('title.tag') }}</small>
        </h1>
      </div>
    </div>
  </div>

  {%- for post in page.posts.toArray() %}
    {{ partial('_macro/post.njk', {post: post, is_index: true}) }}
  {%- endfor %}

  {%- include '_partials/pagination.njk' -%}

{% endblock %}

{% block sidebar %}
  {{ sidebar_template.render(false) }}
{% endblock %}
