{
  "name": "hexo-site",
  "version": "0.0.0",
  "private": true,
  "packageManager": "pnpm@10.17.1",
  "scripts": {
    "theme:apply": "sh tools/apply-next-overrides.sh",
    "theme:watch": "pnpm exec chokidar \"overrides/**/*\" \"tools/apply-next-overrides.sh\" -i \"**/.DS_Store\" --debounce 200 -c \"pnpm run theme:apply\"",
    "build": "pnpm run theme:apply && pnpm exec hexo generate && touch public/.nojekyll",
    "clean": "pnpm exec hexo clean",
    "deploy": "pnpm run theme:apply && pnpm exec hexo clean && pnpm run build && pnpm exec hexo deploy",
    "dev:hexo": "pnpm exec hexo server",
    "dev": "pnpm run theme:apply && pnpm exec concurrently -k -n HEXO,OVERRIDES -c cyan,yellow \"pnpm run dev:hexo\" \"pnpm run theme:watch\"",
    "themes": "git submodule update --remote"
  },
  "hexo": {
    "version": "8.1.1"
  },
  "dependencies": {
    "hexo": "^8.1.1",
    "hexo-deployer-git": "^3.0.0",
    "hexo-generator-archive": "^1.0.0",
    "hexo-generator-category": "^1.0.0",
    "hexo-generator-index": "^2.0.0",
    "hexo-generator-sitemap": "^3.0.1",
    "hexo-generator-tag": "^1.0.0",
    "hexo-renderer-ejs": "^2.0.0",
    "hexo-renderer-marked": "^5.0.0",
    "hexo-renderer-pug": "^3.0.0",
    "hexo-renderer-stylus": "^2.1.0",
    "hexo-server": "^3.0.0",
    "hexo-theme-butterfly": "^5.5.4",
    "hexo-theme-landscape": "^0.0.3",
    "hexo-theme-next": "^8.23.0"
  },
  "devDependencies": {
    "chokidar-cli": "^3.0.0",
    "concurrently": "^9.2.1"
  }
}
